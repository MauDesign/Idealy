// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id    String  @id @default(cuid())
  name  String  @unique
  slug  String  @unique
  color String? // e.g. "#00b4a6" for badge color
  posts Post[]

  @@index([slug])
}

model Post {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  content       String    @db.Text
  summary       String?   @db.Text
  featuredImage String?
  published     Boolean   @default(false)
  locale        String    @default("es")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Taxonomy
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  tags          String[]  // Keywords/tags for SEO and filtering

  // SEO fields
  seoTitle       String?
  seoDescription String?
  canonicalUrl   String?  // Optional canonical URL override
  
  // Translation Linkage
  translationGroupId String? // Relaciona el mismo articulo en distintos idiomas

  @@index([slug])
  @@index([locale])
  @@index([categoryId])
  @@index([published, locale])
  @@index([translationGroupId])
}

model Media {
  id        String   @id @default(cuid())
  url       String   @unique
  name      String?
  type      String?
  size      Int?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
